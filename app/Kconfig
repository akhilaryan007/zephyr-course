# #     default BLINK_SLEEP_2500MS

# # config BLINK_SLEEP_250MS
# #     bool "250 ms"

# # config BLINK_SLEEP_2500MS
# #     bool "2500 ms"

# # config BLINK_SLEEP_3000MS
# #     bool "3000 ms"

# # endchoice

# # config BLINK_SLEEP_TIME_MS
# #     int 
# #     default 250 if BLINK_SLEEP_250MS
# #     default 2500 if BLINK_SLEEP_2500MS
# #     default 3000 if BLINK_SLEEP_3000MS
# #     default 0
# #     #range 100 5000
# #     help
# #       help string can be multiple lines
# #       and will be shown in the menuconfig interface when the user selects this option.

# # # -------------------------------
# # # Advanced Settings (submenu)
# # # -------------------------------
# # menuconfig LED_ADVANCED
# #     bool "Advanced LED settings"
# #     default n

# # if LED_ADVANCED

# # config LED_BRIGHTNESS
# #     int "LED brightness"
# #     range 0 100
# #     default 100

# # config LED_FADE_DURATION
# #     int "LED fade duration (ms)"
# #     range 0 5000
# #     default 500

# # # -------------------------------
# # # Expert Settings (visible if)
# # # -------------------------------
# # menu "Expert settings"
# #     visible if LED_ADVANCED

# # config LED_DEBUG
# #     bool "Enable LED debugging"
# #     default n

# # config LED_CUSTOM_PATTERN
# #     bool "Custom blink pattern"
# #     default n

# # endmenu

# # endif # LED_ADVANCED

# # #endif # LED_SUBSYSTEM

# # source "Kconfig.zephyr"


menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y

if LED_SUBSYSTEM

# -------------------------------
# Blink sleep time (submenu)
# -------------------------------
menu "LED blink sleep time"

choice LED_BLINK_PATTERN
    prompt "Select the LED blinking pattern"
    default BLINK_SLEEP_500MS

config BLINK_SLEEP_250MS
    bool "250 ms"

config BLINK_SLEEP_500MS
    bool "500 ms"

config BLINK_SLEEP_1000MS
    bool "1s (medium)"

config BLINK_SLEEP_2000MS
    bool "2s"

endchoice

endmenu

# Hidden mapping
config BLINK_SLEEP_TIME_MS
    int
    default 250 if BLINK_SLEEP_250MS
    default 500 if BLINK_SLEEP_500MS
    default 1000 if BLINK_SLEEP_1000MS
    default 2000 if BLINK_SLEEP_2000MS

config APP_HEARTBEAT_PERIOD_MS
    int "Heartbeat period (ms)"
    range 100 2000
    default 500

# -------------------------------
# Advanced Settings (submenu)
# -------------------------------
menuconfig LED_ADVANCED
    bool "Advanced LED settings"
    default n

if LED_ADVANCED

config LED_BRIGHTNESS
    int "LED brightness"
    range 0 100
    default 100

config LED_FADE_DURATION
    int "LED fade duration (ms)"
    range 0 5000
    default 500

# -------------------------------
# Expert Settings
# -------------------------------
menu "Expert settings"

config LED_DEBUG
    bool "Enable LED debugging"
    default n

config LED_CUSTOM_PATTERN
    bool "Custom blink pattern"
    default n

endmenu

endif # LED_ADVANCED

endif # LED_SUBSYSTEM

source "Kconfig.zephyr"

